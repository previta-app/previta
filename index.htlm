<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="theme-color" content="#1a7a4a">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="PREVITA">
<title>PREVITA – Prevenção + Vida</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap');
  :root {
    --verde:#1a7a4a;--verde-claro:#e8f5ee;--laranja:#f5821f;--laranja-claro:#fff3e8;
    --cinza:#f2f4f6;--cinza-texto:#6b7280;--texto:#1a1e2b;--sombra:0 2px 12px rgba(0,0,0,0.10);--radius:16px;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Nunito',sans-serif;background:#f0f4f2;color:var(--texto);min-height:100vh;max-width:480px;margin:0 auto;padding-bottom:80px;}

  .header{background:linear-gradient(135deg,#1a7a4a,#0d4f2e);color:white;padding:14px 14px 18px;position:sticky;top:0;z-index:100;border-radius:0 0 22px 22px;box-shadow:0 4px 20px rgba(26,122,74,0.35);}
  .header-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
  .logo-area{display:flex;align-items:center;gap:10px;}
  .logo-box{width:46px;height:46px;background:white;border-radius:13px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,0.2);flex-shrink:0;}
  .logo-text h1{font-size:21px;font-weight:900;letter-spacing:-0.5px;}
  .logo-text p{font-size:10px;opacity:0.8;font-weight:600;}
  .header-data{font-size:10px;opacity:0.75;text-align:right;font-weight:600;}
  .membro-bar{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,0.15);border-radius:11px;padding:7px 11px;}
  .membro-nome{font-size:12px;font-weight:800;flex:1;}
  .membro-trocar{background:rgba(255,255,255,0.25);border:none;color:white;border-radius:7px;padding:3px 9px;font-size:10px;font-weight:800;cursor:pointer;font-family:Nunito,sans-serif;}
  .alerta-badge{background:var(--laranja);color:white;border-radius:20px;padding:2px 8px;font-size:10px;font-weight:800;}

  .nav-tabs{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:white;display:flex;border-top:1px solid #e5e7eb;box-shadow:0 -4px 20px rgba(0,0,0,0.08);z-index:200;}
  .tab-btn{flex:1;padding:9px 2px 7px;border:none;background:none;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:2px;color:var(--cinza-texto);font-family:Nunito,sans-serif;font-size:9px;font-weight:700;transition:color 0.2s;}
  .tab-btn.ativa{color:var(--verde);}
  .tab-btn .icon{font-size:19px;}

  .tela{display:none;padding:13px;}
  .tela.ativa{display:block;}

  .card{background:white;border-radius:var(--radius);padding:13px;margin-bottom:11px;box-shadow:var(--sombra);}
  .card-titulo{font-size:13px;font-weight:800;color:var(--verde);margin-bottom:10px;display:flex;align-items:center;gap:5px;}

  .remedio-item{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--cinza);}
  .remedio-item:last-child{border-bottom:none;padding-bottom:0;}
  .remedio-cor{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:19px;flex-shrink:0;}
  .remedio-info{flex:1;}
  .remedio-nome{font-size:13px;font-weight:800;}
  .remedio-dose{font-size:10px;color:var(--cinza-texto);font-weight:600;margin-top:1px;}
  .remedio-horarios{margin-top:3px;display:flex;gap:3px;flex-wrap:wrap;}
  .horario-badge{background:var(--verde-claro);color:var(--verde);border-radius:5px;padding:1px 6px;font-size:9px;font-weight:700;}
  .check-btn{width:32px;height:32px;border-radius:9px;border:2px solid #d1d5db;background:none;cursor:pointer;font-size:15px;display:flex;align-items:center;justify-content:center;transition:all 0.2s;flex-shrink:0;}
  .check-btn.tomado{background:var(--verde);border-color:var(--verde);color:white;}

  .btn-verde{width:100%;padding:12px;background:var(--verde);color:white;border:none;border-radius:11px;font-size:14px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;font-family:Nunito,sans-serif;transition:background 0.2s;}
  .btn-verde:hover{background:#145c38;}
  .btn-laranja{background:var(--laranja);color:white;border:none;border-radius:11px;padding:10px 16px;font-size:12px;font-weight:800;cursor:pointer;font-family:Nunito,sans-serif;}
  .btn-cinza{background:var(--cinza);color:var(--cinza-texto);border:none;border-radius:11px;padding:10px 16px;font-size:12px;font-weight:800;cursor:pointer;font-family:Nunito,sans-serif;}

  .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:500;align-items:flex-end;justify-content:center;}
  .modal-overlay.aberto{display:flex;}
  .modal{background:white;border-radius:22px 22px 0 0;width:100%;max-width:480px;padding:20px 16px 28px;max-height:88vh;overflow-y:auto;}
  .modal h2{font-size:16px;font-weight:900;margin-bottom:13px;color:var(--verde);}
  .campo{margin-bottom:11px;}
  .campo label{font-size:11px;font-weight:700;color:var(--cinza-texto);display:block;margin-bottom:4px;}
  .campo input,.campo select,.campo textarea{width:100%;padding:10px;border:2px solid #e5e7eb;border-radius:9px;font-size:13px;font-family:Nunito,sans-serif;font-weight:600;color:var(--texto);background:white;}
  .campo input:focus,.campo select:focus,.campo textarea:focus{outline:none;border-color:var(--verde);}
  .horarios-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:4px;}
  .horario-toggle{padding:7px 3px;border:2px solid #e5e7eb;border-radius:8px;background:none;font-size:10px;font-weight:700;cursor:pointer;font-family:Nunito,sans-serif;text-align:center;}
  .horario-toggle.sel{background:var(--verde-claro);border-color:var(--verde);color:var(--verde);}
  .modal-fechar{position:absolute;top:13px;right:14px;background:none;border:none;font-size:21px;cursor:pointer;color:var(--cinza-texto);}

  .agenda-item{display:flex;align-items:center;gap:9px;padding:9px;background:var(--cinza);border-radius:11px;margin-bottom:6px;}
  .agenda-hora{font-size:13px;font-weight:900;color:var(--verde);min-width:46px;text-align:center;}
  .agenda-info{flex:1;}
  .agenda-nome{font-size:12px;font-weight:800;}
  .agenda-dose{font-size:10px;color:var(--cinza-texto);font-weight:600;}
  .vazio{text-align:center;padding:26px;color:var(--cinza-texto);font-size:12px;font-weight:600;}

  .stats-row{display:flex;gap:7px;margin-bottom:11px;}
  .stat-box{flex:1;background:white;border-radius:13px;padding:10px;text-align:center;box-shadow:var(--sombra);}
  .stat-num{font-size:24px;font-weight:900;color:var(--verde);}
  .stat-label{font-size:9px;color:var(--cinza-texto);font-weight:700;}

  .progresso-bar{height:6px;background:#e5e7eb;border-radius:10px;margin:6px 0;overflow:hidden;}
  .progresso-fill{height:100%;background:var(--verde);border-radius:10px;transition:width 0.3s;}

  .ia-chat{min-height:180px;max-height:300px;overflow-y:auto;margin-bottom:9px;}
  .msg{margin-bottom:8px;display:flex;flex-direction:column;}
  .msg.user{align-items:flex-end;}
  .msg.ia{align-items:flex-start;}
  .msg-bubble{max-width:85%;padding:8px 12px;border-radius:14px;font-size:12px;font-weight:600;line-height:1.5;}
  .msg.user .msg-bubble{background:var(--verde);color:white;border-radius:14px 14px 4px 14px;}
  .msg.ia .msg-bubble{background:white;color:var(--texto);border-radius:14px 14px 14px 4px;box-shadow:var(--sombra);}
  .ia-input-row{display:flex;gap:7px;}
  .ia-input{flex:1;padding:10px 12px;border:2px solid #e5e7eb;border-radius:11px;font-size:13px;font-family:Nunito,sans-serif;font-weight:600;}
  .ia-input:focus{outline:none;border-color:var(--verde);}
  .btn-enviar{width:44px;height:44px;background:var(--verde);border:none;border-radius:11px;color:white;font-size:17px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .digitando{display:flex;gap:4px;padding:9px 12px;}
  .dot{width:7px;height:7px;background:var(--verde);border-radius:50%;animation:bounce 1s infinite;}
  .dot:nth-child(2){animation-delay:0.15s}.dot:nth-child(3){animation-delay:0.3s}
  @keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}

  .membro-card{background:white;border-radius:13px;padding:11px 13px;margin-bottom:7px;box-shadow:var(--sombra);display:flex;align-items:center;gap:11px;cursor:pointer;border:2px solid transparent;}
  .membro-card.ativo{border-color:var(--verde);background:var(--verde-claro);}
  .membro-avatar{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}

  .rodape{text-align:center;font-size:9px;color:#9ca3af;padding:10px 12px;line-height:1.8;font-weight:600;border-top:1px solid #f0f0f0;margin-top:6px;}

  #fotoPreview{width:100%;border-radius:10px;margin-top:8px;display:none;}
  @keyframes pulse{from{transform:scale(1)}to{transform:scale(1.15)}}
</style>
</head>
<body>

<div class="header">
  <div class="header-top">
    <div class="logo-area">
      <div class="logo-box">
        <!-- LOGO PREVITA SVG -->
        <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="36" height="36" rx="9" fill="#e8f5ee"/>
          <path d="M18 3L5 9.5V18c0 7.5 5.5 14 13 15.5C25.5 32 31 25.5 31 18V9.5L18 3z" fill="#1a7a4a"/>
          <rect x="15.5" y="11" width="5" height="11" rx="2.5" fill="white"/>
          <rect x="11" y="15.5" width="14" height="5" rx="2.5" fill="white"/>
        </svg>
      </div>
      <div class="logo-text">
        <h1>PREVITA</h1>
        <p>Prevenção + Vida</p>
      </div>
    </div>
    <div class="header-data" id="headerData"></div>
  </div>
  <div class="membro-bar">
    <span style="font-size:15px" id="membroIconeHeader">👤</span>
    <span class="membro-nome" id="membroNomeHeader">Selecione um membro</span>
    <div class="alerta-badge" id="badgeHoje">✅</div>
    <button class="membro-trocar" onclick="irPara('membros',document.querySelectorAll('.tab-btn')[4])">Trocar</button>
  </div>
</div>

<!-- REMÉDIOS -->
<div class="tela ativa" id="tela-remedios">
  <div class="stats-row">
    <div class="stat-box"><div class="stat-num" id="statTotal">0</div><div class="stat-label">Remédios</div></div>
    <div class="stat-box"><div class="stat-num" id="statTomados" style="color:var(--laranja)">0</div><div class="stat-label">Tomados</div></div>
    <div class="stat-box"><div class="stat-num" id="statPendentes" style="color:#ef4444">0</div><div class="stat-label">Pendentes</div></div>
  </div>
  <div class="card">
    <div class="card-titulo">💊 Remédios Contínuos</div>
    <div id="listaRemedios"><div class="vazio">Nenhum remédio.<br>Adicione abaixo! 👇</div></div>
  </div>
  <button class="btn-verde" onclick="abrirModal()">➕ Adicionar Remédio</button>
  <div class="rodape">
    ⚠️ Este app não substitui prescrição ou orientação médica.<br>
    <strong>Desenvolvido por Wilson Foster</strong><br>
    ACS – UBS São Pedro – Santana de Parnaíba – SP<br>
    Foster Engenharia &amp; Desenvolvimento Digital
  </div>
</div>

<!-- AGENDA -->
<div class="tela" id="tela-agenda">
  <div class="card">
    <div class="card-titulo">📅 Agenda de Hoje</div>
    <div id="agendaHoje"><div class="vazio">Sem remédios agendados.</div></div>
  </div>
  <div class="card">
    <div class="card-titulo">📊 Progresso</div>
    <div style="display:flex;justify-content:space-between;font-size:11px;font-weight:700;color:var(--cinza-texto)">
      <span>Doses tomadas</span><span id="progrTexto">0 / 0</span>
    </div>
    <div class="progresso-bar"><div class="progresso-fill" id="progrBar" style="width:0%"></div></div>
    <div style="font-size:10px;color:var(--cinza-texto);font-weight:600;text-align:center" id="progrMsg">Cadastre seus remédios!</div>
  </div>
  <div class="card" style="background:var(--verde-claro);border:2px solid var(--verde)">
    <div style="font-size:12px;font-weight:800;color:var(--verde);margin-bottom:7px">🔔 Alertas Sonoros</div>
    <div style="font-size:10px;color:var(--cinza-texto);font-weight:600;margin-bottom:9px">Mantenha o app aberto para receber alertas com som e vibração.</div>
    <div style="display:flex;gap:7px">
      <button class="btn-laranja" onclick="testarSom()" style="flex:1;border-radius:9px;padding:9px">🔔 Testar Som</button>
      <button class="btn-verde" onclick="instalarPWA()" style="flex:1">📲 Instalar</button>
    </div>
  </div>
</div>

<!-- RECEITA -->
<div class="tela" id="tela-receita">
  <div class="card" style="background:linear-gradient(135deg,#1565c0,#0d47a1);color:white;border:none">
    <div style="display:flex;align-items:center;gap:9px;margin-bottom:5px">
      <div style="font-size:26px">🏥</div>
      <div>
        <div style="font-size:13px;font-weight:900">Importar Receita</div>
        <div style="font-size:9px;opacity:0.8;font-weight:600">UBS São Pedro – Santana de Parnaíba – SP</div>
      </div>
    </div>
    <div style="font-size:10px;opacity:0.85;font-weight:600">Tire foto da receita física ou cole os nomes. A IA configura os horários automaticamente!</div>
  </div>

  <!-- FOTO DA RECEITA -->
  <div class="card">
    <div class="card-titulo">📷 Fotografar Receita Física</div>
    <div style="font-size:11px;color:var(--cinza-texto);font-weight:600;margin-bottom:9px">Tire uma foto da sua receita médica e a IA vai ler os remédios automaticamente.</div>
    <input type="file" id="fotoInput" accept="image/*" capture="environment" style="display:none" onchange="processarFoto(this)">
    <button class="btn-verde" onclick="document.getElementById('fotoInput').click()" style="margin-bottom:8px">
      📷 Abrir Câmera / Galeria
    </button>
    <img id="fotoPreview" alt="Foto da receita">
    <div id="fotoStatus" style="display:none;text-align:center;padding:9px;font-size:12px;font-weight:700;color:var(--verde)">⏳ Lendo receita com IA...</div>
  </div>

  <!-- DIGITAR RECEITA -->
  <div class="card">
    <div class="card-titulo">⌨️ Ou Digite / Cole os Remédios</div>
    <div class="campo">
      <textarea id="receitaTexto" rows="4" placeholder="Losartana Potássica 50mg&#10;Sinvastatina 20mg&#10;Metoprolol 50mg&#10;Hidroclorotiazida 25mg"></textarea>
    </div>
    <button class="btn-verde" onclick="processarReceita()" id="btnProcessar">🤖 Processar e Criar Alertas</button>
    <div id="receitaStatus" style="display:none;text-align:center;padding:9px;font-size:12px;font-weight:700;color:var(--verde)">⏳ Processando com IA...</div>
  </div>

  <div class="card" id="receitaResultado" style="display:none">
    <div class="card-titulo">✅ Remédios Identificados</div>
    <div id="receitaLista"></div>
    <div style="display:flex;gap:7px;margin-top:11px">
      <button class="btn-verde" onclick="importarSelecionados()" style="flex:2">➕ Adicionar aos Remédios</button>
      <button class="btn-cinza" onclick="limparReceita()" style="flex:1">🗑️</button>
    </div>
  </div>

  <div class="card" style="background:var(--verde-claro);border:2px solid var(--verde)">
    <div style="font-size:11px;font-weight:800;color:var(--verde);margin-bottom:4px">💡 Como usar</div>
    <div style="font-size:10px;color:var(--cinza-texto);font-weight:600;line-height:1.7">
      1. Tire foto da receita médica físicab<strong>OU</strong> cole os nomes<br>
      2. Clique em Processar<br>
      3. A IA identifica e define horários ideais<br>
      4. Confirme e os alertas são criados! 🔔
    </div>
  </div>
</div>

<!-- ASSISTENTE IA -->
<div class="tela" id="tela-ia">
  <div class="card" style="background:linear-gradient(135deg,#1a7a4a,#0d4f2e);color:white;border:none;text-align:center;padding:28px 20px">
    <div style="font-size:56px;margin-bottom:10px">🤖</div>
    <div style="font-size:20px;font-weight:900;margin-bottom:4px">PREV</div>
    <div style="font-size:12px;opacity:0.85;font-weight:600;margin-bottom:16px">Assistente de Saúde PREVITA<br>Powered by Claude AI</div>
    <a href="https://claude.ai" target="_blank" style="display:block;background:white;color:#1a7a4a;border-radius:14px;padding:14px;font-size:15px;font-weight:900;text-decoration:none;font-family:Nunito,sans-serif;margin-bottom:10px">
      💬 Abrir Assistente PREV
    </a>
    <div style="font-size:10px;opacity:0.75;font-weight:600">Abre o Claude AI gratuitamente no seu navegador</div>
  </div>

  <div class="card">
    <div class="card-titulo">💡 Como usar o PREV</div>
    <div style="font-size:12px;color:var(--cinza-texto);font-weight:600;line-height:1.8">
      1. Clique em <strong>"Abrir Assistente PREV"</strong><br>
      2. Crie uma conta gratuita no Claude AI<br>
      3. Pergunte sobre seus remédios à vontade!<br>
      4. Volte ao PREVITA para registrar suas doses ✅
    </div>
  </div>

  <div class="card" style="background:var(--laranja-claro);border:2px solid var(--laranja)">
    <div style="font-size:12px;font-weight:800;color:var(--laranja);margin-bottom:8px">💊 Sugestões de perguntas</div>
    <div style="display:flex;flex-direction:column;gap:6px">
      <a href="https://claude.ai" target="_blank" style="text-align:left;background:white;border:1px solid #fcd9b2;border-radius:8px;padding:8px 11px;font-size:11px;font-weight:700;cursor:pointer;font-family:Nunito,sans-serif;text-decoration:none;color:var(--texto);display:block">💊 Pra que serve a Metformina?</a>
      <a href="https://claude.ai" target="_blank" style="text-align:left;background:white;border:1px solid #fcd9b2;border-radius:8px;padding:8px 11px;font-size:11px;font-weight:700;cursor:pointer;font-family:Nunito,sans-serif;text-decoration:none;color:var(--texto);display:block">⚠️ Losartana com Aspirina?</a>
      <a href="https://claude.ai" target="_blank" style="text-align:left;background:white;border:1px solid #fcd9b2;border-radius:8px;padding:8px 11px;font-size:11px;font-weight:700;cursor:pointer;font-family:Nunito,sans-serif;text-decoration:none;color:var(--texto);display:block">⏰ Horário ideal para remédio de pressão?</a>
      <a href="https://claude.ai" target="_blank" style="text-align:left;background:white;border:1px solid #fcd9b2;border-radius:8px;padding:8px 11px;font-size:11px;font-weight:700;cursor:pointer;font-family:Nunito,sans-serif;text-decoration:none;color:var(--texto);display:block">❓ Esqueci o remédio, e agora?</a>
    </div>
  </div>

  <div class="rodape">
    ⚠️ Este app não substitui prescrição ou orientação médica.<br>
    <strong>Desenvolvido por Wilson Foster</strong><br>
    ACS – UBS São Pedro – Santana de Parnaíba – SP<br>
    Foster Engenharia &amp; Desenvolvimento Digital
  </div>
</div>

<!-- FAMÍLIA -->
<div class="tela" id="tela-membros">
  <div class="card" style="background:linear-gradient(135deg,var(--verde),#145c38);color:white;border:none">
    <div style="font-size:14px;font-weight:900;margin-bottom:3px">👨‍👩‍👧‍👦 Membros da Família</div>
    <div style="font-size:10px;opacity:0.8;font-weight:600">Cada membro tem seus próprios remédios e alertas independentes.</div>
  </div>
  <div id="listaMembros"></div>
  <button class="btn-verde" onclick="abrirModalMembro()">➕ Adicionar Membro</button>
  <div class="rodape">
    Dados armazenados apenas neste dispositivo. LGPD – Lei 13.709/2018<br>
    <strong>Desenvolvido por Wilson Foster</strong><br>
    ACS – UBS São Pedro – Santana de Parnaíba – SP<br>
    Foster Engenharia &amp; Desenvolvimento Digital
  </div>
</div>

<!-- TABS -->
<nav class="nav-tabs">
  <button class="tab-btn ativa" onclick="irPara('remedios',this)"><span class="icon">💊</span>Remédios</button>
  <button class="tab-btn" onclick="irPara('agenda',this)"><span class="icon">📅</span>Agenda</button>
  <button class="tab-btn" onclick="irPara('receita',this)"><span class="icon">📋</span>Receita</button>
  <button class="tab-btn" onclick="irPara('ia',this)"><span class="icon">🤖</span>PREV</button>
  <button class="tab-btn" onclick="irPara('membros',this)"><span class="icon">👨‍👩‍👧</span>Família</button>
</nav>

<!-- MODAL REMÉDIO -->
<div class="modal-overlay" id="modalRemedio">
  <div class="modal" style="position:relative">
    <button class="modal-fechar" onclick="fecharModal()">✕</button>
    <h2>➕ Novo Remédio</h2>
    <div class="campo"><label>Nome *</label><input type="text" id="mNome" placeholder="Ex: Losartana 50mg"></div>
    <div class="campo"><label>Dosagem</label><input type="text" id="mDose" placeholder="Ex: 1 comprimido"></div>
    <div class="campo"><label>Horários</label><div class="horarios-grid" id="horariosGrid"></div></div>
    <div class="campo"><label>Observação</label><input type="text" id="mObs" placeholder="Ex: Tomar com água"></div>
    <button class="btn-verde" onclick="salvarRemedio()" style="margin-top:7px">💾 Salvar</button>
  </div>
</div>

<!-- MODAL MEMBRO -->
<div class="modal-overlay" id="modalMembro">
  <div class="modal" style="position:relative">
    <button class="modal-fechar" onclick="fecharModalMembro()">✕</button>
    <h2>👤 Novo Membro</h2>
    <div class="campo"><label>Nome *</label><input type="text" id="mmNome" placeholder="Ex: Vovó Maria"></div>
    <div class="campo">
      <label>Ícone</label>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:5px" id="iconeGrid"></div>
    </div>
    <button class="btn-verde" onclick="salvarMembro()" style="margin-top:7px">💾 Salvar</button>
  </div>
</div>

<script>
const HORARIOS=['06:00','07:00','08:00','09:00','12:00','14:00','18:00','20:00','21:00','22:00'];
const EMOJIS=['💊','🔵','🔴','🟡','🟢','🟠','⚪','🟣'];
const CORES=['#e8f5ee','#e8f0ff','#ffe8e8','#fff8e1','#e8fff4','#fff3e8','#f5f5f5','#f3e8ff'];
const API_URL='https://api.anthropic.com/v1/messages';
const API_HEADERS={'Content-Type':'application/json','anthropic-dangerous-direct-browser-access':'true'};

let membros=JSON.parse(localStorage.getItem('pv_membros')||'null');
if(!membros){membros=[{id:1,nome:'Eu',icone:'👤'}];localStorage.setItem('pv_membros',JSON.stringify(membros));}

let membroAtualId=parseInt(localStorage.getItem('pv_membro_atual')||membros[0].id);
let membroAtual=membros.find(m=>m.id===membroAtualId)||membros[0];

function chaveM(s){return 'pv_'+s+'_'+membroAtual.id;}
function hoje(){return new Date().toISOString().split('T')[0];}

let remedios=JSON.parse(localStorage.getItem(chaveM('remedios'))||'[]');
let tomadosHoje=JSON.parse(localStorage.getItem(chaveM('tomados')+'_'+hoje())||'{}');
let ultimosAlertas=JSON.parse(localStorage.getItem(chaveM('alertas')+'_'+hoje())||'{}');
let receitaProcessada=[];
let horasSel=[];
let iconeSelMembro='👴';
let deferredPrompt=null;
let audioCtx=null;

window.addEventListener('beforeinstallprompt',e=>{e.preventDefault();deferredPrompt=e;});

function trocarMembro(id){
  membroAtualId=id;membroAtual=membros.find(m=>m.id===id);
  localStorage.setItem('pv_membro_atual',id);
  remedios=JSON.parse(localStorage.getItem(chaveM('remedios'))||'[]');
  tomadosHoje=JSON.parse(localStorage.getItem(chaveM('tomados')+'_'+hoje())||'{}');
  ultimosAlertas=JSON.parse(localStorage.getItem(chaveM('alertas')+'_'+hoje())||'{}');
  atualizarHeader();renderRemedios();renderMembros();
  mostrarToast('👤 '+membroAtual.nome+' selecionado!');
}

function irPara(tela,btn){
  document.querySelectorAll('.tela').forEach(t=>t.classList.remove('ativa'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('ativa'));
  document.getElementById('tela-'+tela).classList.add('ativa');
  btn.classList.add('ativa');
  if(tela==='agenda')renderAgenda();
  if(tela==='membros')renderMembros();
}

function atualizarHeader(){
  const now=new Date();
  const dias=['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  const meses=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  document.getElementById('headerData').innerHTML=`${dias[now.getDay()]}, ${now.getDate()} ${meses[now.getMonth()]}<br>${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;
  document.getElementById('membroIconeHeader').textContent=membroAtual.icone||'👤';
  document.getElementById('membroNomeHeader').textContent=membroAtual.nome;
  let pendentes=0;
  const agoraStr=`${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;
  remedios.forEach(r=>r.horarios.forEach(h=>{if(h<=agoraStr&&!tomadosHoje[r.id+'_'+h])pendentes++;}));
  document.getElementById('badgeHoje').textContent=pendentes>0?pendentes+'⚠️':'✅';
}

function renderRemedios(){
  const lista=document.getElementById('listaRemedios');
  if(!remedios.length){lista.innerHTML='<div class="vazio">Nenhum remédio cadastrado.<br>Adicione abaixo! 👇</div>';}
  else{
    lista.innerHTML=remedios.map((r,i)=>{
      const tom=r.horarios.filter(h=>tomadosHoje[r.id+'_'+h]).length,total=r.horarios.length;
      return `<div class="remedio-item">
        <div class="remedio-cor" style="background:${CORES[i%CORES.length]}">${EMOJIS[i%EMOJIS.length]}</div>
        <div class="remedio-info">
          <div class="remedio-nome">${r.nome}</div>
          <div class="remedio-dose">${r.dose||'1 unidade'}${r.obs?' · '+r.obs:''}</div>
          <div class="remedio-horarios">${r.horarios.map(h=>`<span class="horario-badge">${h}</span>`).join('')}</div>
          ${tom>0?`<div style="font-size:9px;color:var(--verde);font-weight:700;margin-top:2px">✅ ${tom}/${total} hoje</div>`:''}
        </div>
        <button class="check-btn ${tom===total&&total>0?'tomado':''}" onclick="marcarTodos(${r.id})">${tom===total&&total>0?'✓':'○'}</button>
      </div>`;
    }).join('');
  }
  atualizarStats();
}

function marcarTodos(id){
  const r=remedios.find(x=>x.id===id);if(!r)return;
  const todos=r.horarios.every(h=>tomadosHoje[id+'_'+h]);
  r.horarios.forEach(h=>{if(todos)delete tomadosHoje[id+'_'+h];else tomadosHoje[id+'_'+h]=true;});
  localStorage.setItem(chaveM('tomados')+'_'+hoje(),JSON.stringify(tomadosHoje));
  renderRemedios();atualizarHeader();
}

function atualizarStats(){
  let tom=0,pend=0;
  remedios.forEach(r=>r.horarios.forEach(h=>{if(tomadosHoje[r.id+'_'+h])tom++;else pend++;}));
  document.getElementById('statTotal').textContent=remedios.length;
  document.getElementById('statTomados').textContent=tom;
  document.getElementById('statPendentes').textContent=pend;
}

function abrirModal(){
  horasSel=[];['mNome','mDose','mObs'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('horariosGrid').innerHTML=HORARIOS.map(h=>`<button class="horario-toggle" onclick="toggleHorario(this,'${h}')">${h}</button>`).join('');
  document.getElementById('modalRemedio').classList.add('aberto');
}
function fecharModal(){document.getElementById('modalRemedio').classList.remove('aberto');}
function toggleHorario(btn,h){
  if(horasSel.includes(h)){horasSel=horasSel.filter(x=>x!==h);btn.classList.remove('sel');}
  else{horasSel.push(h);btn.classList.add('sel');}
}
function salvarRemedio(){
  const nome=document.getElementById('mNome').value.trim();
  if(!nome){alert('Digite o nome!');return;}
  if(!horasSel.length){alert('Selecione um horário!');return;}
  remedios.push({id:Date.now(),nome,dose:document.getElementById('mDose').value.trim(),horarios:horasSel.sort(),obs:document.getElementById('mObs').value.trim()});
  localStorage.setItem(chaveM('remedios'),JSON.stringify(remedios));
  fecharModal();renderRemedios();atualizarHeader();mostrarToast('✅ Remédio adicionado!');
}

function renderAgenda(){
  const now=new Date();
  const agoraStr=`${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;
  let itens=[];
  remedios.forEach(r=>r.horarios.forEach(h=>itens.push({hora:h,nome:r.nome,dose:r.dose,id:r.id,key:r.id+'_'+h})));
  itens.sort((a,b)=>a.hora.localeCompare(b.hora));
  const div=document.getElementById('agendaHoje');
  div.innerHTML=itens.length?itens.map(it=>{
    const tomado=tomadosHoje[it.key],passado=it.hora<=agoraStr;
    return `<div class="agenda-item" style="${tomado?'opacity:0.55':''}">
      <div class="agenda-hora" style="${passado&&!tomado?'color:#ef4444':''}">${it.hora}</div>
      <div class="agenda-info"><div class="agenda-nome">${it.nome}</div><div class="agenda-dose">${it.dose||'1 unidade'}</div></div>
      <div style="font-size:19px;cursor:pointer" onclick="marcarItem('${it.key}')">${tomado?'✅':passado?'❌':'⏳'}</div>
    </div>`;
  }).join(''):'<div class="vazio">Sem remédios agendados.</div>';
  const total=itens.length,tom=itens.filter(i=>tomadosHoje[i.key]).length;
  document.getElementById('progrTexto').textContent=`${tom} / ${total}`;
  document.getElementById('progrBar').style.width=total?`${Math.round(tom/total*100)}%`:'0%';
  document.getElementById('progrMsg').textContent=total===0?'Cadastre seus remédios!':tom===total?'🎉 Todos os remédios tomados!':tom===0?'💪 Vamos começar!':'Faltam '+(total-tom)+' dose'+(total-tom>1?'s':'');
}

function marcarItem(key){
  if(tomadosHoje[key])delete tomadosHoje[key];else tomadosHoje[key]=true;
  localStorage.setItem(chaveM('tomados')+'_'+hoje(),JSON.stringify(tomadosHoje));
  renderAgenda();renderRemedios();atualizarHeader();
}

function renderMembros(){
  document.getElementById('listaMembros').innerHTML=membros.map(m=>`
    <div class="membro-card ${m.id===membroAtualId?'ativo':''}" onclick="trocarMembro(${m.id})">
      <div class="membro-avatar" style="background:${m.id===membroAtualId?'var(--verde)':'var(--verde-claro)'};color:${m.id===membroAtualId?'white':'inherit'}">${m.icone||'👤'}</div>
      <div style="flex:1">
        <div style="font-size:14px;font-weight:800">${m.nome}</div>
        <div style="font-size:10px;color:var(--cinza-texto);font-weight:600">${(JSON.parse(localStorage.getItem('pv_remedios_'+m.id)||'[]')).length} remédio(s)</div>
      </div>
      ${m.id===membroAtualId?'<div style="font-size:10px;font-weight:800;color:var(--verde)">✅ ATIVO</div>':''}
    </div>`).join('');
}

function abrirModalMembro(){
  document.getElementById('mmNome').value='';
  iconeSelMembro='👴';
  const icones=['👴','👵','👨','👩','👦','👧','🧑','👶'];
  document.getElementById('iconeGrid').innerHTML=icones.map(ic=>`<span style="font-size:26px;cursor:pointer;padding:4px;border-radius:7px;border:2px solid transparent" id="ic_${ic.codePointAt(0)}" onclick="selecionarIcone('${ic}')">${ic}</span>`).join('');
  document.getElementById('modalMembro').classList.add('aberto');
}
function fecharModalMembro(){document.getElementById('modalMembro').classList.remove('aberto');}
function selecionarIcone(ic){
  iconeSelMembro=ic;
  document.querySelectorAll('#iconeGrid span').forEach(el=>el.style.border='2px solid transparent');
  const el=document.getElementById('ic_'+ic.codePointAt(0));
  if(el)el.style.border='2px solid var(--verde)';
}
function salvarMembro(){
  const nome=document.getElementById('mmNome').value.trim();
  if(!nome){alert('Digite o nome!');return;}
  membros.push({id:Date.now(),nome,icone:iconeSelMembro});
  localStorage.setItem('pv_membros',JSON.stringify(membros));
  fecharModalMembro();renderMembros();mostrarToast('👤 '+nome+' adicionado!');
}

// ========== CHAMADA API CENTRAL ==========
async function chamarAPI(system,userContent){
  const body={model:'claude-sonnet-4-6',max_tokens:1000,system,messages:[{role:'user',content:userContent}]};
  let resp;
  try {
    resp=await fetch(API_URL,{method:'POST',headers:API_HEADERS,body:JSON.stringify(body)});
  } catch(err) {
    throw new Error('Sem conexão com a internet ou bloqueio de rede. Verifique sua conexão.');
  }
  if(!resp.ok){
    let err='';
    try{err=await resp.text();}catch(e){}
    if(resp.status===401)throw new Error('Chave de API inválida (401).');
    if(resp.status===429)throw new Error('Muitas requisições. Aguarde um momento.');
    throw new Error('Erro '+resp.status+': '+err.substring(0,100));
  }
  const data=await resp.json();
  return (data.content&&data.content[0]&&data.content[0].text)||'';
}

// ========== RECEITA FOTO ==========
async function processarFoto(input){
  const file=input.files[0];if(!file)return;
  const preview=document.getElementById('fotoPreview');
  const reader=new FileReader();
  reader.onload=async(e)=>{
    preview.src=e.target.result;preview.style.display='block';
    document.getElementById('fotoStatus').style.display='block';
    document.getElementById('fotoStatus').textContent='⏳ Lendo receita com IA...';
    try{
      const base64=e.target.result.split(',')[1];
      const mediaType=file.type||'image/jpeg';
      const body={
        model:'claude-sonnet-4-6',max_tokens:1000,
        system:`Você é um assistente farmacêutico do PREVITA. Analise a imagem da receita médica e retorne SOMENTE JSON válido:
[{"nome":"Nome","dose":"1 comprimido","horarios":["08:00"],"obs":"dica curta"}]
- Extraia TODOS os medicamentos visíveis na receita
- Define horários ideais para cada um
- Retorne APENAS o JSON array, sem texto extra`,
        messages:[{role:'user',content:[
          {type:'image',source:{type:'base64',media_type:mediaType,data:base64}},
          {type:'text',text:'Leia todos os medicamentos desta receita médica e retorne o JSON.'}
        ]}]
      };
      const resp=await fetch(API_URL,{method:'POST',headers:API_HEADERS,body:JSON.stringify(body)});
      if(!resp.ok)throw new Error('API '+resp.status);
      const data=await resp.json();
      const txt=(data.content&&data.content[0]&&data.content[0].text)||'[]';
      receitaProcessada=JSON.parse(txt.replace(/```json|```/g,'').trim());
      document.getElementById('fotoStatus').textContent='✅ '+receitaProcessada.length+' remédio(s) identificado(s)!';
      renderReceitaResultado();
    }catch(e){
      document.getElementById('fotoStatus').textContent='❌ Erro ao ler foto. Tente digitar os remédios abaixo.';
      document.getElementById('fotoStatus').style.color='#ef4444';
      setTimeout(()=>{document.getElementById('fotoStatus').style.display='none';document.getElementById('fotoStatus').style.color='var(--verde)';},5000);
    }
  };
  reader.readAsDataURL(file);
}

// ========== RECEITA TEXTO ==========
async function processarReceita(){
  const texto=document.getElementById('receitaTexto').value.trim();
  if(!texto){alert('Cole os remédios primeiro!');return;}
  document.getElementById('receitaStatus').style.display='block';
  document.getElementById('receitaResultado').style.display='none';
  document.getElementById('btnProcessar').disabled=true;
  try{
    const txt=await chamarAPI(
      `Você é assistente farmacêutico do PREVITA. Analise e retorne SOMENTE JSON:
[{"nome":"Nome","dose":"1 comprimido","horarios":["08:00"],"obs":"dica"}]
Retorne APENAS o JSON array.`,
      'Medicamentos:\n'+texto
    );
    receitaProcessada=JSON.parse(txt.replace(/```json|```/g,'').trim());
    document.getElementById('receitaStatus').style.display='none';
    document.getElementById('btnProcessar').disabled=false;
    renderReceitaResultado();
  }catch(e){
    document.getElementById('receitaStatus').textContent='❌ Erro: '+e.message;
    document.getElementById('receitaStatus').style.color='#ef4444';
    document.getElementById('btnProcessar').disabled=false;
    setTimeout(()=>{document.getElementById('receitaStatus').style.display='none';document.getElementById('receitaStatus').style.color='var(--verde)';document.getElementById('receitaStatus').textContent='⏳ Processando com IA...';},5000);
  }
}

function renderReceitaResultado(){
  if(!receitaProcessada.length)return;
  document.getElementById('receitaLista').innerHTML=receitaProcessada.map((r,i)=>`
    <div style="padding:9px 0;border-bottom:1px solid var(--cinza);display:flex;align-items:center;gap:9px">
      <div style="font-size:20px">${['💊','🔵','🔴','🟡','🟢','🟠'][i%6]}</div>
      <div style="flex:1">
        <div style="font-size:12px;font-weight:800">${r.nome}</div>
        <div style="font-size:10px;color:var(--cinza-texto);font-weight:600">${r.dose}${r.obs?' · '+r.obs:''}</div>
        <div style="display:flex;gap:3px;margin-top:2px;flex-wrap:wrap">${r.horarios.map(h=>`<span class="horario-badge">${h}</span>`).join('')}</div>
      </div>
      <input type="checkbox" checked style="width:17px;height:17px;accent-color:var(--verde)" id="sel_${i}">
    </div>`).join('');
  document.getElementById('receitaResultado').style.display='block';
}

function importarSelecionados(){
  let imp=0;
  receitaProcessada.forEach((r,i)=>{
    const cb=document.getElementById('sel_'+i);
    if(cb&&cb.checked&&!remedios.find(x=>x.nome.toLowerCase()===r.nome.toLowerCase())){
      remedios.push({id:Date.now()+i,nome:r.nome,dose:r.dose,horarios:r.horarios,obs:r.obs||''});imp++;
    }
  });
  localStorage.setItem(chaveM('remedios'),JSON.stringify(remedios));
  renderRemedios();atualizarHeader();
  mostrarToast('✅ '+imp+' remédio'+(imp!==1?'s':'')+' importado'+(imp!==1?'s':'')+'!');
  limparReceita();
  irPara('remedios',document.querySelectorAll('.tab-btn')[0]);
}

function limparReceita(){
  receitaProcessada=[];
  document.getElementById('receitaTexto').value='';
  document.getElementById('receitaResultado').style.display='none';
  const p=document.getElementById('fotoPreview');p.style.display='none';p.src='';
  document.getElementById('fotoStatus').style.display='none';
  document.getElementById('fotoInput').value='';
}

// ========== ASSISTENTE IA ==========
async function enviarIA(){
  const input=document.getElementById('iaInput');
  const msg=input.value.trim();if(!msg)return;
  input.value='';
  const chat=document.getElementById('iaChat');
  chat.innerHTML+=`<div class="msg user"><div class="msg-bubble">${msg}</div></div>`;
  const typing=document.createElement('div');
  typing.className='msg ia';
  typing.innerHTML='<div class="msg-bubble digitando"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>';
  chat.appendChild(typing);chat.scrollTop=chat.scrollHeight;
  try{
    const texto=await chamarAPI(
      `Você é assistente de saúde do PREVITA, criado por Wilson Foster, ACS da UBS São Pedro, microárea 09, Santana de Parnaíba-SP. Responda em português claro e acolhedor para todas as idades. Fale sobre: para que serve o medicamento, horários ideais, efeitos colaterais comuns, interações simples, dicas de adesão. SEMPRE oriente a consultar médico ou farmacêutico. Nunca prescreva doses ou substitua consulta médica.`,
      msg
    );
    typing.remove();
    chat.innerHTML+=`<div class="msg ia"><div class="msg-bubble">${texto.replace(/\n/g,'<br>')}</div></div>`;
  }catch(e){
    typing.remove();
    chat.innerHTML+=`<div class="msg ia"><div class="msg-bubble">⚠️ Não foi possível conectar ao assistente. Verifique sua internet e tente novamente.<br><small style="color:#9ca3af">Erro: ${e.message}</small></div></div>`;
  }
  chat.scrollTop=chat.scrollHeight;
}

function perguntaRapida(txt){document.getElementById('iaInput').value=txt;enviarIA();}

// ========== ALERTA SONORO ==========
function getAudioCtx(){if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();return audioCtx;}
function tocarMelodia(){
  const ctx=getAudioCtx();
  [523.25,659.25,783.99,659.25,783.99,1046.50].forEach((freq,i)=>{
    const osc=ctx.createOscillator(),gain=ctx.createGain();
    osc.connect(gain);gain.connect(ctx.destination);osc.type='sine';osc.frequency.value=freq;
    const s=ctx.currentTime+i*0.23;
    gain.gain.setValueAtTime(0,s);gain.gain.linearRampToValueAtTime(0.5,s+0.02);gain.gain.linearRampToValueAtTime(0,s+0.18);
    osc.start(s);osc.stop(s+0.25);
  });
}
function vibrar(){if(navigator.vibrate)navigator.vibrate([400,100,400,100,600]);}
function testarSom(){tocarMelodia();vibrar();mostrarToast('🔔 Som e vibração OK!');}

function dispararAlerta(r,h){
  const chave=r.id+'_'+h;
  if(ultimosAlertas[chave])return;
  ultimosAlertas[chave]=true;
  localStorage.setItem(chaveM('alertas')+'_'+hoje(),JSON.stringify(ultimosAlertas));
  tocarMelodia();vibrar();
  let rep=0;const loop=setInterval(()=>{rep++;tocarMelodia();vibrar();if(rep>=2)clearInterval(loop);},2200);
  const ex=document.getElementById('modalAlertaSonoro');if(ex)ex.remove();
  const modal=document.createElement('div');
  modal.id='modalAlertaSonoro';
  modal.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:9999;display:flex;align-items:center;justify-content:center;padding:18px';
  modal.innerHTML=`<div style="background:white;border-radius:22px;padding:22px 18px;width:100%;max-width:350px;text-align:center;box-shadow:0 8px 40px rgba(0,0,0,0.3)">
    <div style="font-size:56px;margin-bottom:5px;animation:pulse 0.8s infinite alternate">💊</div>
    <div style="font-size:11px;font-weight:700;color:#6b7280;margin-bottom:3px">HORA DO REMÉDIO · ${membroAtual.icone} ${membroAtual.nome}</div>
    <div style="font-size:20px;font-weight:900;color:#1a7a4a;margin-bottom:3px">${r.nome}</div>
    <div style="font-size:13px;font-weight:700;margin-bottom:3px">${r.dose||'1 unidade'}</div>
    <div style="font-size:24px;font-weight:900;color:#f5821f;margin-bottom:16px">⏰ ${h}</div>
    ${r.obs?`<div style="font-size:11px;color:#6b7280;font-weight:600;margin-bottom:12px;background:#f2f4f6;border-radius:8px;padding:6px">💡 ${r.obs}</div>`:''}
    <button onclick="confirmarTomado('${r.id}','${h}')" style="width:100%;padding:13px;background:#1a7a4a;color:white;border:none;border-radius:11px;font-size:15px;font-weight:900;cursor:pointer;font-family:Nunito,sans-serif;margin-bottom:7px">✅ Tomei!</button>
    <button onclick="adiarAlerta('${r.id}','${h}')" style="width:100%;padding:10px;background:#f2f4f6;color:#6b7280;border:none;border-radius:11px;font-size:12px;font-weight:800;cursor:pointer;font-family:Nunito,sans-serif">⏰ Lembrar em 10 min</button>
  </div>`;
  document.body.appendChild(modal);
}

function confirmarTomado(id,h){
  tomadosHoje[id+'_'+h]=true;
  localStorage.setItem(chaveM('tomados')+'_'+hoje(),JSON.stringify(tomadosHoje));
  document.getElementById('modalAlertaSonoro')?.remove();
  renderRemedios();atualizarHeader();mostrarToast('✅ Remédio tomado!');
}

function adiarAlerta(id,h){
  document.getElementById('modalAlertaSonoro')?.remove();mostrarToast('⏰ Lembrete em 10 min!');
  setTimeout(()=>{
    const r=remedios.find(x=>x.id==id);
    if(r){delete ultimosAlertas[id+'_'+h];localStorage.setItem(chaveM('alertas')+'_'+hoje(),JSON.stringify(ultimosAlertas));dispararAlerta(r,h);}
  },600000);
}

function verificarAlertas(){
  const now=new Date();
  const h=`${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;
  remedios.forEach(r=>r.horarios.forEach(ho=>{if(ho===h&&!tomadosHoje[r.id+'_'+ho])dispararAlerta(r,ho);}));
}

function mostrarToast(msg){
  const t=document.createElement('div');
  t.style.cssText='position:fixed;bottom:88px;left:50%;transform:translateX(-50%);background:#1a1e2b;color:white;padding:9px 16px;border-radius:11px;font-size:12px;font-weight:700;font-family:Nunito,sans-serif;z-index:8000;box-shadow:0 4px 16px rgba(0,0,0,0.3);white-space:nowrap;';
  t.textContent=msg;document.body.appendChild(t);setTimeout(()=>t.remove(),3000);
}

function instalarPWA(){
  if(deferredPrompt){deferredPrompt.prompt();deferredPrompt.userChoice.then(()=>{deferredPrompt=null;});}
  else alert('Para instalar:\n\n📱 Chrome/Android: Menu ⋮ → "Adicionar à tela inicial"\n\n🍎 Safari/iPhone: Compartilhar → "Adicionar à Tela de Início"');
}

const styleEl=document.createElement('style');
styleEl.textContent='@keyframes pulse{from{transform:scale(1)}to{transform:scale(1.15)}}';
document.head.appendChild(styleEl);

document.addEventListener('touchstart',()=>getAudioCtx(),{once:true});
document.addEventListener('click',()=>getAudioCtx(),{once:true});

atualizarHeader();
renderRemedios();
setInterval(atualizarHeader,60000);
setInterval(verificarAlertas,60000);
setTimeout(verificarAlertas,2000);
</script>
</body>
</html>
